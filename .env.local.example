# Database (direct Postgres connection for Drizzle ORM — admin/migration use)
DATABASE_URL=

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated admin emails for access to /admin
ADMIN_EMAILS=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI Provider (set one — Vercel AI Gateway is recommended)
VERCEL_AI_KEY=
# Direct provider keys (fallback if not using gateway)
GOOGLE_GENERATIVE_AI_API_KEY=
OPENAI_API_KEY=

# USDA FoodData Central API (free key from https://fdc.nal.usda.gov/api-key-signup)
# Falls back to DEMO_KEY with rate limits if not set
USDA_API_KEY=

# Langfuse observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=

# Optional AI cost tracking:
# JSON map keyed by model name, e.g. {"your-model":{"inputPer1M":0,"outputPer1M":0}}
AI_MODEL_PRICING_JSON=

# Resend email alerts
# When configured, every AI run completion/failure sends an email.
RESEND_API_KEY=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# Optional alerting controls
OPS_NOTIFY_ON_SUCCESS=false
AI_JOB_COST_ALERT_THRESHOLD_USD=
AI_USAGE_ALERT_THRESHOLD_USD=

# Telegram Bot (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Discord Bot (from Discord Developer Portal)
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=
DISCORD_APPLICATION_ID=

# WhatsApp Bot (from Meta Business / WhatsApp Cloud API)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# App URL (for generating web links from bot)
NEXT_PUBLIC_APP_URL=

# Upstash Redis (rate limiting — optional, limits are skipped if not set)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cron / API protection
CRON_SECRET=
