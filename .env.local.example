# Database (direct Postgres connection for Drizzle + Better Auth)
DATABASE_URL=

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI Provider (set one — Vercel AI Gateway is recommended)
VERCEL_AI_KEY=
# Direct provider keys (fallback if not using gateway)
GOOGLE_GENERATIVE_AI_API_KEY=
OPENAI_API_KEY=

# USDA FoodData Central API (free key from https://fdc.nal.usda.gov/api-key-signup)
# Falls back to DEMO_KEY with rate limits if not set
USDA_API_KEY=

# Langfuse observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=

# Telegram Bot (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Discord Bot (from Discord Developer Portal)
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=
DISCORD_APPLICATION_ID=

# App URL (for generating web links from bot)
NEXT_PUBLIC_APP_URL=

# Cron / API protection
CRON_SECRET=
